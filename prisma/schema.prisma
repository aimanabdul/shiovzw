generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Achievement {
  id            Int      @id @default(autoincrement())
  title         String
  slug          String   @unique
  description   String
  tags          String
  coverImage    String
  galleryImages String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdminUser {
  id           Int    @id @default(autoincrement())
  email        String @unique
  passwordHash String
}
